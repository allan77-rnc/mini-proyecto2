rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — owner-only read, Admin SDK writes
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // usernames/{username} — public read for availability checks, Admin SDK writes
    match /usernames/{username} {
      allow read: if true;
      allow write: if false;
    }

    // rooms/{roomId} — any authenticated user can read, Admin SDK writes
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if false;

      // messages/{messageId} — authenticated users can read, Admin SDK writes
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
