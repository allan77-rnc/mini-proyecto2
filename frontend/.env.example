# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000

# Firebase project credentials — copy to .env.local and fill in your values
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: restrict registration to a specific email domain (e.g. university.edu)
# If unset, any valid email is accepted.
VITE_INSTITUTIONAL_DOMAIN=
